{
	"info": {
		"name": "Event Ticketing System API",
		"description": "Postman collection for KPL Event Ticketing System (Clean Architecture & DDD)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Events",
			"item": [
				{
					"name": "Create Event",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"SUMUN 2026 Conference\",\n  \"description\": \"Surabaya Model United Nations\",\n  \"location\": \"Surabaya\",\n  \"max_capacity\": 500,\n  \"start_date\": \"2026-08-01T08:00:00Z\",\n  \"end_date\": \"2026-08-03T17:00:00Z\",\n  \"categories\": [\n    {\n      \"name\": \"Regular\",\n      \"price\": 150000,\n      \"quota\": 300,\n      \"sales_start_date\": \"2026-07-01T00:00:00Z\",\n      \"sales_end_date\": \"2026-07-31T23:59:59Z\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/events/",
							"host": ["{{baseUrl}}"],
							"path": ["events", ""]
						}
					}
				},
				{
					"name": "Publish Event",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/{{event_id}}/publish",
							"host": ["{{baseUrl}}"],
							"path": ["events", "{{event_id}}", "publish"]
						}
					}
				},
				{
					"name": "Get Available Events",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/available",
							"host": ["{{baseUrl}}"],
							"path": ["events", "available"]
						}
					}
				},
				{
					"name": "Get Event Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/{{event_id}}",
							"host": ["{{baseUrl}}"],
							"path": ["events", "{{event_id}}"]
						}
					}
				},
				{
					"name": "Get Event Participants",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/{{event_id}}/participants",
							"host": ["{{baseUrl}}"],
							"path": ["events", "{{event_id}}", "participants"]
						}
					}
				},
				{
					"name": "Cancel Event",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/{{event_id}}/cancel",
							"host": ["{{baseUrl}}"],
							"path": ["events", "{{event_id}}", "cancel"]
						}
					}
				},
				{
					"name": "Disable Ticket Category",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/events/{{event_id}}/categories/{{category_id}}/disable",
							"host": ["{{baseUrl}}"],
							"path": ["events", "{{event_id}}", "categories", "{{category_id}}", "disable"]
						}
					}
				}
			]
		},
		{
			"name": "2. Bookings",
			"item": [
				{
					"name": "Create Booking",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"event_id\": \"{{event_id}}\",\n  \"ticket_category_id\": \"{{category_id}}\",\n  \"quantity\": 2\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/bookings/",
							"host": ["{{baseUrl}}"],
							"path": ["bookings", ""]
						}
					}
				},
				{
					"name": "Pay Booking",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"payment_amount\": 300000\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/bookings/{{booking_id}}/pay",
							"host": ["{{baseUrl}}"],
							"path": ["bookings", "{{booking_id}}", "pay"]
						}
					}
				},
				{
					"name": "Expire Booking",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/bookings/{{booking_id}}/expire",
							"host": ["{{baseUrl}}"],
							"path": ["bookings", "{{booking_id}}", "expire"]
						}
					}
				}
			]
		},
		{
			"name": "3. Tickets",
			"item": [
				{
					"name": "Get Purchased Tickets",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/tickets/purchased?customer_id={{customer_id}}",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "purchased"],
							"query": [
								{ "key": "customer_id", "value": "{{customer_id}}" }
							]
						}
					}
				},
				{
					"name": "Check-in Ticket",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"event_id\": \"{{event_id}}\",\n  \"ticket_code\": \"TICKET-CODE-HERE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tickets/check-in",
							"host": ["{{baseUrl}}"],
							"path": ["tickets", "check-in"]
						}
					}
				}
			]
		},
		{
			"name": "4. Refunds",
			"item": [
				{
					"name": "Request Refund",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"booking_id\": \"{{booking_id}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/refunds/request",
							"host": ["{{baseUrl}}"],
							"path": ["refunds", "request"]
						}
					}
				},
				{
					"name": "Approve Refund",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/refunds/{{refund_id}}/approve",
							"host": ["{{baseUrl}}"],
							"path": ["refunds", "{{refund_id}}", "approve"]
						}
					}
				},
				{
					"name": "Reject Refund",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Bukti tidak valid\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/refunds/{{refund_id}}/reject",
							"host": ["{{baseUrl}}"],
							"path": ["refunds", "{{refund_id}}", "reject"]
						}
					}
				},
				{
					"name": "Mark Refund Paid Out",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"payment_reference\": \"TRANSFER-REF-12345\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/refunds/{{refund_id}}/payout",
							"host": ["{{baseUrl}}"],
							"path": ["refunds", "{{refund_id}}", "payout"]
						}
					}
				}
			]
		},
		{
			"name": "5. Reports",
			"item": [
				{
					"name": "Get Event Sales Report",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reports/sales?event_id={{event_id}}",
							"host": ["{{baseUrl}}"],
							"path": ["reports", "sales"],
							"query": [
								{ "key": "event_id", "value": "{{event_id}}" }
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		},
		{
			"key": "event_id",
			"value": "your-event-uuid-here",
			"type": "string"
		},
		{
			"key": "category_id",
			"value": "your-category-uuid-here",
			"type": "string"
		},
		{
			"key": "customer_id",
			"value": "your-customer-uuid-here",
			"type": "string"
		},
		{
			"key": "booking_id",
			"value": "your-booking-uuid-here",
			"type": "string"
		},
		{
			"key": "refund_id",
			"value": "your-refund-uuid-here",
			"type": "string"
		}
	]
}